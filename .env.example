# ============================================================================
# Real-Time Analytics Engine — environment configuration
# Copy to `.env` and adjust as needed. All services read from this file.
# ============================================================================

# --- Kafka -------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9092
TICKS_TOPIC=market.ticks
DLQ_TOPIC=market.ticks.dlq
TICKS_PARTITIONS=8

# --- Producer ----------------------------------------------------------------
EVENTS_PER_SECOND=2500
SYMBOLS=AAPL,MSFT,GOOG,AMZN,NVDA
MALFORMED_RATE=0.001
PRODUCER_LOG_INTERVAL_SECONDS=5

# --- Consumer ----------------------------------------------------------------
CONSUMER_GROUP=analytics-consumer
WINDOW_SECONDS=10
TICK_INTERVAL_SECONDS=1.0
DB_BATCH_SIZE=200
DB_BATCH_INTERVAL_MS=500
WS_HOST=0.0.0.0
WS_PORT=8765
WS_SEND_TIMEOUT_SECONDS=1.0

# --- TimescaleDB -------------------------------------------------------------
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics
POSTGRES_DB=analytics
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432

# --- Frontend ----------------------------------------------------------------
FRONTEND_EXTERNAL_PORT=8080
